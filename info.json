{
  "name": "doodle",
  "version": "1.0.0",
  "title": "Doodle",
  "author": "djfariel",
  "homepage": "https://github.com/djfariel/doodle",
  "factorio_version": "2.1",
  "description": "Map chart annotation: line, arrow, square, circle, and eraser tools via EMOF Chart Controls.",
  "dependencies": [
    "base >= 2.1",
    "extensible-map-overlay-framework >= 1.0.0"
  ],
  "package": {
    "ignore": [
      ".git/**",
      ".gitignore",
      ".idea/**",
      ".vscode/**",
      ".editorconfig",
      "README.md",
      "description.md",
      "gallery/**",
      "gallery/*.jpg",
      "gallery/*.jpeg",
      "**/*.zip",
      "Thumbs.db",
      ".DS_Store"
    ],
    "gallery": [
      "gallery/*.png"
    ],
    "prune_gallery": true,
    "readme": "description.md",
    "sync_portal_details": true,
    "zipLocation": "outside"
  }
}
